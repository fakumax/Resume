---
import '../index.css';
import { themes } from '@/styles/theme';
import type { Lang } from '@/i18n/languageContext';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path: string;
  altPath: string;
}

const { lang, title, description, path, altPath } = Astro.props;

const canonicalURL = new URL(path, Astro.site);
const altLang: Lang = lang === 'es' ? 'en' : 'es';
const altURL = new URL(altPath, Astro.site);
const esURL = new URL(lang === 'es' ? path : altPath, Astro.site);
const enURL = new URL(lang === 'en' ? path : altPath, Astro.site);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Facundo Vergara',
  jobTitle: 'Software Engineer',
  url: Astro.site?.toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Posadas',
    addressRegion: 'Misiones',
    addressCountry: 'AR',
  },
  sameAs: ['https://github.com/fakumax/', 'https://www.linkedin.com/in/fakumax/'],
  knowsAbout: [
    'SharePoint Online',
    'SPFx',
    'React',
    'TypeScript',
    'Power Automate',
    'Power Apps',
    'Microsoft 365',
  ],
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={esURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={esURL} />
    <link rel="alternate" hreflang={altLang} href={altURL} />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'es' ? 'es_AR' : 'en_US'} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />

    <script define:vars={{ darkBg: themes.dark.bg, lightBg: themes.light.bg }} is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('color-mode');
          var mode =
            stored === 'light' || stored === 'dark'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = mode;
          document.documentElement.style.backgroundColor = mode === 'dark' ? darkBg : lightBg;
        } catch {
          /* localStorage unavailable, fall back to default light theme */
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
