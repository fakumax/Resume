---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { App } from '@/App';

const title = 'Facundo Vergara | Web development & automation';
const description =
  'Websites, online stores, booking systems, automations and custom applications for businesses in Argentina.';
---

<BaseLayout lang="en" title={title} description={description} path="/en/" altPath="/">
  <App client:load lang="en" altLangHref="/" />
</BaseLayout>
