---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { App } from '@/App';

const title = 'Facundo Vergara | Desarrollo web y automatización';
const description =
  'Sitios web, tiendas online, sistemas de reservas, automatizaciones y aplicaciones a medida para negocios en Posadas y Argentina.';
---

<BaseLayout lang="es" title={title} description={description} path="/" altPath="/en/">
  <App client:load lang="es" altLangHref="/en/" />
</BaseLayout>
