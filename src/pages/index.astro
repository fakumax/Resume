---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { App } from '@/App';

const title = 'Facundo Vergara — Software Engineer';
const description =
  'Software Engineer especializado en soluciones empresariales sobre SharePoint Online y Microsoft 365, con experiencia en SPFx, React, TypeScript, Power Automate y Power Apps.';
---

<BaseLayout lang="es" title={title} description={description} path="/" altPath="/en/">
  <App client:load lang="es" altLangHref="/en/" />
</BaseLayout>
